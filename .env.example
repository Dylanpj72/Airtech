# ─── Email / Lead Handling ──────────────────────────────────────────────────
# Resend API key — sign up at resend.com to send lead notification emails
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Email address that receives incoming lead form submissions
CONTACT_EMAIL=raymond@airtech.co.za

# ─── Analytics ──────────────────────────────────────────────────────────────
# Google Analytics 4 measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Meta (Facebook) Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=XXXXXXXXXXXXXXXXXX

# ─── Site ────────────────────────────────────────────────────────────────────
# Canonical site URL — used for OG tags and sitemap generation
NEXT_PUBLIC_SITE_URL=https://www.airtech.co.za